{
  "name": "ai-markdown-feedback",
  "displayName": "Ace: AI Markdown Feedback",
  "description": "Annotate Markdown files in VS Code with structured feedback for Claude, Codex, and other LLMs — highlight, comment, suggest edits, and mark deletions.",
  "version": "0.4.1",
  "license": "MIT",
  "publisher": "AlfredNaayem",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/41fred/ai-markdown-feedback"
  },
  "homepage": "https://github.com/41fred/ai-markdown-feedback#readme",
  "bugs": {
    "url": "https://github.com/41fred/ai-markdown-feedback/issues"
  },
  "keywords": [
    "markdown",
    "feedback",
    "annotations",
    "ai",
    "llm",
    "claude",
    "codex",
    "ai-review",
    "markdown-preview",
    "annotation"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "acemd.previewEditor",
        "displayName": "AI Markdown Preview",
        "selector": [
          { "filenamePattern": "*.md" }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "acemd.openPreview",
        "title": "Ace: Open Feedback Preview",
        "icon": {
          "light": "media/preview-light.svg",
          "dark": "media/preview-dark.svg"
        }
      },
      {
        "command": "acemd.insertHighlight",
        "title": "Ace: Highlight Selection"
      },
      {
        "command": "acemd.insertComment",
        "title": "Ace: Add Comment"
      },
      {
        "command": "acemd.insertEdit",
        "title": "Ace: Suggest Edit"
      },
      {
        "command": "acemd.insertDelete",
        "title": "Ace: Suggest Deletion"
      },
      {
        "command": "acemd.clearAllAnnotations",
        "title": "Ace: Clear All Annotations"
      },
      {
        "command": "acemd.copyAIInstructions",
        "title": "Ace: Copy AI Instructions"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == markdown",
          "command": "acemd.openPreview",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == markdown && editorHasSelection",
          "command": "acemd.insertHighlight",
          "group": "aimd@1"
        },
        {
          "when": "resourceLangId == markdown && editorHasSelection",
          "command": "acemd.insertComment",
          "group": "aimd@2"
        },
        {
          "when": "resourceLangId == markdown && editorHasSelection",
          "command": "acemd.insertEdit",
          "group": "aimd@3"
        },
        {
          "when": "resourceLangId == markdown && editorHasSelection",
          "command": "acemd.insertDelete",
          "group": "aimd@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "acemd.openPreview",
        "key": "ctrl+k ctrl+v",
        "mac": "cmd+k cmd+v",
        "when": "resourceLangId == markdown"
      },
      {
        "command": "acemd.insertHighlight",
        "key": "ctrl+k h",
        "mac": "cmd+k h",
        "when": "editorTextFocus && resourceLangId == markdown && editorHasSelection"
      },
      {
        "command": "acemd.insertComment",
        "key": "ctrl+k c",
        "mac": "cmd+k c",
        "when": "editorTextFocus && resourceLangId == markdown"
      },
      {
        "command": "acemd.insertEdit",
        "key": "ctrl+k e",
        "mac": "cmd+k e",
        "when": "editorTextFocus && resourceLangId == markdown"
      },
      {
        "command": "acemd.insertDelete",
        "key": "ctrl+k d",
        "mac": "cmd+k d",
        "when": "editorTextFocus && resourceLangId == markdown && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Ace: AI Markdown Feedback",
      "properties": {
        "acemd.highlightColor": {
          "type": "string",
          "default": "#fff3a0",
          "description": "Background color for highlighted text"
        },
        "acemd.showAnnotationGutter": {
          "type": "boolean",
          "default": true,
          "description": "Show annotation markers in the gutter"
        },
        "acemd.autoSaveAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save the file after each annotation is applied from the preview"
        },
        "acemd.autoOpenPreview": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the Ace preview when a Markdown file becomes active"
        },
        "acemd.headerFormat": {
          "type": "string",
          "enum": ["markdown", "html"],
          "default": "markdown",
          "enumDescriptions": [
            "Visible Markdown callout — stronger signal for AI tools (recommended)",
            "Hidden HTML comment — invisible in source but often ignored by AI tools"
          ],
          "description": "Format of the instruction header auto-inserted when the first annotation is added. Markdown is recommended because AI tools are more likely to follow visible instructions."
        },
        "acemd.autoOpenMode": {
          "type": "string",
          "enum": ["side", "replace"],
          "default": "side",
          "enumDescriptions": [
            "Open a side-by-side preview next to the editor",
            "Replace the editor with a preview-only view (no code visible)"
          ],
          "description": "How auto-open preview behaves: side-by-side or preview-only"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "markdown-it": "^14.0.0"
  }
}
